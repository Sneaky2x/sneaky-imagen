{
  "tests": [
    {
      "name": "basic_generation",
      "input": {
        "prompt": "a cyberpunk cat, 8k, detailed",
        "width": 512,
        "height": 512,
        "steps": 5,
        "output_format": "JPEG",
        "output_quality": 75
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "MODEL_TYPE",
        "value": "SDXL"
      }
    ]
  }
}
